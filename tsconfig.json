{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "types": [
      "bun-types",
      "node"
    ],
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": [
    "app.manifest.ts",
    "src/**/*.ts"
  ]
}
